# ---------------------------------------------------------------------------
# ASA cluster container settings - copy to ".env" and edit, then deploy.
#
# IMPORTANT: keep ADMIN_PASSWORD, JOIN_PASSWORD, CLUSTER_ID, MODS and the
# ports in sync with ../config.ini (the tooling reads config.ini).
# ---------------------------------------------------------------------------

# Absolute base directory on the VPS holding all cluster data + tooling.
BASE_DIR=/opt/asa-cluster

# Shared cluster id (identical on all maps so transfers work).
CLUSTER_ID=arkcluster01

# CurseForge mod IDs applied to every map:
#   940975 = Cybers Structures QoL+ (Crossplay)
#   929169 = Configurable Cryopods
#   928548 = Shiny! Dinos Ascended
MODS=940975,929169,928548

# RCON + admin password (cheats/RCON). CHANGE THIS.
ADMIN_PASSWORD=adminpass123

# Join password (leave empty for an open/public cluster).
JOIN_PASSWORD=

# Player cap per map.
MAX_PLAYERS=70

# Game (UDP) + RCON (TCP) ports per map. RCON is bound to 127.0.0.1 only.
ISLAND_GAME_PORT=7777
ISLAND_RCON_PORT=27020
SCORCHED_GAME_PORT=7778
SCORCHED_RCON_PORT=27021
VALGUERO_GAME_PORT=7779
VALGUERO_RCON_PORT=27022
LOSTCOLONY_GAME_PORT=7780
LOSTCOLONY_RCON_PORT=27023
