# =====================================================================
#  ARK Survival Ascended - Unified Cluster Configuration (EXAMPLE)
#
#  Copy this to "config.ini" and fill in your values. config.ini is
#  git-ignored because it holds secrets. Shared by the Discord bot,
#  watchdog, and crash analyzer.
#
#  IMPORTANT: cluster-wide values here (admin_password, join_password,
#  cluster_id, mods, ports) MUST match deploy/.env.
# =====================================================================

[cluster]
base_dir = /opt/asa-cluster
compose_project = asa-cluster
cluster_id = arkcluster01

# CurseForge mod IDs installed on every map:
#   940975 = Cybers Structures QoL+ (Crossplay)
#   929169 = Configurable Cryopods
#   928548 = Shiny! Dinos Ascended
mods = 940975,929169,928548

# RCON + admin password (must match deploy/.env ADMIN_PASSWORD). CHANGE THIS.
admin_password = CHANGE_ME

# Optional join password (blank = open). Must match deploy/.env JOIN_PASSWORD.
join_password =

max_players = 70
rcon_host = 127.0.0.1

[discord]
# Bot token from the Discord Developer Portal (required for the bot to start).
token = YOUR_DISCORD_BOT_TOKEN

# Comma-separated Discord role / user IDs.
admin_role_ids =
owner_user_ids =

# The single text channel the bot is locked to: all slash commands must be run
# here, and the bot posts update notifications here. Enable Developer Mode in
# Discord, right-click the channel -> Copy Channel ID. Blank = allow anywhere.
channel_id =

# Legacy fallback, only used for update posts when channel_id is blank.
alerts_channel_id =

[steamcmd]
asa_app_id = 2430930
update_check_minutes = 15
update_countdown_minutes = 30

[scheduler]
schedule_file = schedules.json
auto_save_minutes = 10

[watchdog]
poll_seconds = 30
fail_threshold = 3
max_restarts = 3
restart_window_minutes = 30
cooldown_minutes = 30
max_memory_mb = 0
memory_poll_seconds = 60
memory_restart_countdown_minutes = 5
log_file = /opt/asa-cluster/watchdog.log
log_days = 30

[servers]
list = island,scorched,valguero,lostcolony

[server.island]
name = The Island
map = TheIsland_WP
game_port = 7777
rcon_port = 27020
container = asa-island
log_file = /opt/asa-cluster/island/server-files/ShooterGame/Saved/Logs/ShooterGame.log

[server.scorched]
name = Scorched Earth
map = ScorchedEarth_WP
game_port = 7778
rcon_port = 27021
container = asa-scorched
log_file = /opt/asa-cluster/scorched/server-files/ShooterGame/Saved/Logs/ShooterGame.log

[server.valguero]
name = Valguero
map = Valguero_WP
game_port = 7779
rcon_port = 27022
container = asa-valguero
log_file = /opt/asa-cluster/valguero/server-files/ShooterGame/Saved/Logs/ShooterGame.log

[server.lostcolony]
name = Lost Colony
map = LostColony_WP
game_port = 7780
rcon_port = 27023
container = asa-lostcolony
log_file = /opt/asa-cluster/lostcolony/server-files/ShooterGame/Saved/Logs/ShooterGame.log
